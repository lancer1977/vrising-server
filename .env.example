# V Rising Server Configuration
# Copy this file to .env and customize as needed

# Data directory for game saves (default: ./data/saves)
# This is where persistent world data is stored
VRISING_DATA_DIR=./data/saves

# Settings directory for server configuration (default: ./data/settings)
# Contains server settings files (serverhostsettings.json, etc.)
VRISING_SETTINGS_DIR=./data/settings

# Optional: Override container name
# CONTAINER_NAME=vrising-server

# Optional: Override image tag
# IMAGE_TAG=latest