# App build / image
APP_BUILD_CONTEXT=.
APP_DOCKERFILE=Dockerfile
APP_LOCAL_IMAGE=example-app:local
APP_IMAGE=ghcr.io/lancer1977/example-app:main

# App runtime
APP_CONTAINER_NAME=example-app-app
APP_CONTAINER_PORT=8080
APP_ENVIRONMENT=Development
APP_CONNECTION_STRING=Data Source=/data/app.db
APP_DATA_VOLUME=example-app-data

# Nginx front door
NGINX_IMAGE=nginx:1.27-alpine
NGINX_CONTAINER_NAME=example-app-nginx
WEB_LOCAL_PORT=8080
WEB_PUBLISHED_PORT=8080

# Optional static frontend mount if the product repo wants Nginx to serve built assets directly.
WEB_STATIC_SOURCE=./site/dist
